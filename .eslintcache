=\"#\"> Get My Cv </a>\n                </button>\n            </div>   \n        </div>\n    )\n}","/media/ridwan/423a36b3-4b63-48c8-895a-b37745b61a8a/my-portofolio/src/Component/Skills/Skills.jsx",[],"/media/ridwan/423a36b3-4b63-48c8-895a-b37745b61a8a/my-portofolio/src/Component/Skills/data.js",[],"/media/ridwan/423a36b3-4b63-48c8-895a-b37745b61a8a/my-portofolio/src/Component/Skills/card.jsx",["66"],"/media/ridwan/423a36b3-4b63-48c8-895a-b37745b61a8a/my-portofolio/src/Component/RecentWorks/RecentWorks.jsx",[],"/media/ridwan/423a36b3-4b63-48c8-895a-b37745b61a8a/my-portofolio/src/Component/Service/Service.jsx",[],"/media/ridwan/423a36b3-4b63-48c8-895a-b37745b61a8a/my-portofolio/src/Component/Footer/Footer.jsx",["67","68","69","70","71","72","73","74","75"],"/media/ridwan/423a36b3-4b63-48c8-895a-b37745b61a8a/my-portofolio/src/Component/Converstaion/Conversation.jsx",["76"],{"ruleId":"77","replacedBy":"78"},{"ruleId":"79","replacedBy":"80"},{"ruleId":"77","replacedBy":"81"},{"ruleId":"79","replacedBy":"82"},{"ruleId":"83","severity":1,"message":"84","line":17,"column":17,"nodeType":"85","endLine":17,"endColumn":29},{"ruleId":"86","severity":1,"message":"87","line":8,"column":13,"nodeType":"85","endLine":8,"endColumn":42},{"ruleId":"88","severity":1,"message":"89","line":5,"column":8,"nodeType":"90","messageId":"91","endLine":5,"endColumn":15},{"ruleId":"88","severity":1,"message":"92","line":6,"column":8,"nodeType":"90","messageId":"91","endLine":6,"endColumn":16},{"ruleId":"88","severity":1,"message":"93","line":12,"column":8,"nodeType":"90","messageId":"91","endLine":12,"endColumn":12},{"ruleId":"83","severity":1,"message":"84","line":24,"column":21,"nodeType":"85","endLine":24,"endColumn":32},{"ruleId":"83","severity":1,"message":"84","line":25,"column":21,"nodeType":"85","endLine":25,"endColumn":32},{"ruleId":"83","severity":1,"message":"84","line":26,"column":21,"nodeType":"85","endLine":26,"endColumn":32},{"ruleId":"83","severity":1,"message":"84","line":27,"col