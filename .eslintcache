,"mtime":1606923599296,"results":"25","hashOfConfig":"14"},{"filePath":"26","messages":"27","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"28"},"zvccw",{"filePath":"29","messages":"30","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"31","messages":"32","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"33"},{"filePath":"34","messages":"35","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"33"},{"filePath":"36","messages":"37","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"38","messages":"39","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"40"},{"filePath":"41","messages":"42","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"43"},{"filePath":"44","messages":"45","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"46","messages":"47","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"48","messages":"49","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"50","messages":"51","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"52","messages":"53","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"54","usedDeprecatedRules":"55"},"/media/ridwan/423a36b3-4b63-48c8-895a-b37745b61a8a/my-portofolio/src/reportWebVitals.js",[],["56","57"],"/media/ridwan/423a36b3-4b63-48c8-895a-b37745b61a8a/my-portofolio/src/App.js",[],"/media/ridwan/423a36b3-4b63-48c8-895a-b37745b61a8a/my-portofolio/src/index.js",[],["58","59"],"/media/ridwan/423a36b3-4b63-48c8-895a-b37745b61a8a/my-portofolio/src/Component/Navbar/Navbar.jsx",[],"/media/ridwan/423a36b3-4b63-48c8-895a-b37745b61a8a/my-portofolio/src/Component/Navbar/Menuitems.js",[],"/media/ridwan/423a36b3-4b63-48c8-895a-b37745b61a8a/my-portofolio/src/Component/Hero/Hero.jsx",[],["60","61"],"/media/ridwan/423a36b3-4b63-48c8-895a-b37745b61a8a/my-portofolio/src/Component/About/About.jsx",["62"],"import './About.scss'\nimport aos from 'aos'\nimport 'aos/dist/aos.css'\nimport { useEffect } from 'react'\n// import cv from '../../Assets/doc/Cv.pdf'\n\nexport default function About() {\n    useEffect(() =>{\n        aos.init({duration:1500});\n    }, []);\n    return(\n        <div className=\"about\" id=\"about\">\n            <span className=\"about__title\" data-aos=\"fade-down\">\n                Hi, I'm Ridwan. Nice to meet you\n            </span>\n            <p className=\"about__caption\" data-aos=\"fade-up\">\n            Hi, I am a Front End Developer. I fresh graduate in informatics engineering in 2019 at the Indraprasta PGRI university. I think front end is my passion because I love coding in web design and problem solving. In making web design I often use ReactJs as a javascript framework, because ReactJs is a reusable component, makes me complete projects quickly. I love making open source projects. It helps me learn many new things and add to my portfolio. besides that I also have the ability to work independently and in teams, but still comply with the work rules that have been determined.\n            </p>\n            <div className=\"about__getcv\">\n                <a href=\"https://drive.google.com/file/d/1KTgAVYZUPnn7ZKkbZtaWQuciUeJ55COc/view\" target=\"_blank\"> Get My CV </a>\n            </div>\n        </div>\n    )\n}","/media/ridwan/423a36b3-4b63-48c8-895a-b37745b61a8a/my-portofolio/src/Component/Skills/Skills.jsx",[],"/media/ridwan/423a36b3-4b63-48c8-895a-b37745b61a8a/my-portofolio/src/Component/RecentWorks/RecentWorks.jsx",[],"/media/ridwan/423a36b3-4b63-48c8-895a-b37745b61a8a/my-portofolio/src/Component/Service/Service.jsx",[],"/media/ridwan/423a36b3-4b63-48c8-895a-b37745b61a8a/my-portofolio/src/Component/Footer/Footer.jsx",["63"],"/media/ridwan/423a36b3-4b63-48c8-895a-b37745b61a8a/my-portofolio/src/Component/Converstaion/Conversation.jsx",["64"],"import './Conversation.scss'\n\nexport default function Conversation() {\n    return(\n        <div className=\"Conver\">\n            <span> \nInterested in collaborating or hiring me?</span>\n            <span> I'm always open to start discussing website creation and product design. </span>\n            <span> Feel free to send a message </span>\n            <a href=\"https://linktr.ee/ridwanndwip\" target=\"_blank\"> Start a Conversation </a>\n        </div>\n    )\n}",["65","66"],{"ruleId":"67","replacedBy":"68"},{"ruleId":"69","replacedBy":"70"},{"ruleId":"67","replacedBy":"71"},{"ruleId":"69","replacedBy":"72"},{"ruleId":"67","replacedBy":"73"},{"ruleId":"69","replacedBy":"74"},{"ruleId":"75","severity":1,"message":"76","line":20,"column":98,"nodeType":"77","endLine":20,"endColumn":113},{"ruleId":"78","severity":1,"message":"79","line":30,"column":38,"nodeType":"80","endLine":30,"endColumn":58},{"ruleId":"75","severity":1,"message":"76","line":10,"column":53,"nodeType":"77","endLine":10,"endColumn":68},{"ruleId":"67","replacedBy":"81"},{"ruleId":"69","replacedBy":"82"},"no-native-reassign",["83"],"no-negated-in-lhs",["84"],["83"],["84"],["83"],["84"],"react/jsx-no-target-blank","Using target=\"_blank\" without rel=\"noreferrer\" is a security risk: see https://html.spec.whatwg.org/multipage/links.html#link-type-noopener","JSXAttribute","jsx-a11y/alt-text","img elements must have an alt prop, either with meaningful text, or an empty string for decorative images.","JSXOpeningElement",["83"],["84"],"no-global-assign","no-unsafe-negation"]