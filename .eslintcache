\n                <CardRw img={img5}/>\n                <CardRw img={img5}/>\n            </div>\n        </div>\n    )\n}","/media/ridwan/423a36b3-4b63-48c8-895a-b37745b61a8a/my-portofolio/src/Component/Service/Service.jsx",[],"/media/ridwan/423a36b3-4b63-48c8-895a-b37745b61a8a/my-portofolio/src/Component/Footer/Footer.jsx",["66","67","68","69","70","71","72","73","74"],"/media/ridwan/423a36b3-4b63-48c8-895a-b37745b61a8a/my-portofolio/src/Component/Converstaion/Conversation.jsx",["75"],"import './Conversation.scss'\n\nexport default function Conversation() {\n    return(\n        <div className=\"Conver\">\n            <span> \nInterested in collaborating or hiring me?</span>\n            <span> I'm always open to start discussing website creation and product design. </span>\n            <span> Feel free to send a message </span>\n            <a href=\"https://linktr.ee/ridwanndwip\" target=\"_blank\"> Start a Conversation </a>\n        </div>\n    )\n}",{"ruleId":"76","replacedBy":"77"},{"ruleId":"78","replacedBy":"79"},{"ruleId":"76","replacedBy":"80"},{"ruleId":"78","replacedBy":"81"},{"ruleId":"76","replacedBy":"82"},{"ruleId":"78","replacedBy":"83"},{"ruleId":"76","replacedBy":"84"},{"ruleId":"78","replacedBy":"85"},{"ruleId":"86","severity":1,"message":"87","line":23,"column":98,"nodeType":"88","endLine":23,"endColumn":113},{"ruleId":"89","severity":1,"message":"90","line":6,"column":8,"nodeType":"91","messageId":"92","endLine":6,"endColumn":12},{"ruleId":"89","severity":1,"message":"93","line":5,"column":8,"nodeType":"91","messageId":"92","endLine":5,"endColumn":15},{"ruleId":"89","severity":1,"message":"94","line":6,"column":8,"nodeType":"91","messageId":"92","endLine":6,"endColumn":16},{"ruleId":"89","severity":1,"message":"95","line":12,"column":8,"nodeType":"91","messageId":"92","endLine":12,"endColumn":12},{"ruleId":"86","severity":1,"message":"87","line":24,"column":61,"nodeType":"88","endLine":24,"endColumn":76},{"ruleId":"86","severity":1,"message":"